{
    "name": "matcha-back",
    "version": "1.0.0",
    "description": "",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/server.js",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "migrate": "tsx ./src/db/manage-db.ts",
        "drop": "tsx ./src/db/manage-db.ts drop",
        "refresh": "tsx ./src/db/manage-db.ts refresh",
        "generate:orm": "tsx ./src/lib/db/orm/generate.ts ./src/db/schema.sql",
        "generate:test:orm": "tsx ./src/lib/db/orm/test/generate.ts ./src/lib/db/orm/test/schema.sql",
        "test": "tsx ./src/lib/db/queries/error-handler.ts"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "dependencies": {
        "@aws-sdk/client-ses": "^3.1042.0",
        "@types/argon2": "^0.14.1",
        "argon2": "^0.44.0",
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.4.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.2",
        "helmet": "^8.1.0",
        "http-status-codes": "^2.3.0",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.10.1",
        "pg": "^8.20.0",
        "redis": "^5.12.1",
        "ua-parser-js": "^2.0.9",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.5.2",
        "@types/pg": "^8.20.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0"
    }
}
